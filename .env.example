FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-secret-key
DATABASE_URL=postgresql://localhost:5432/pea_tracker
# For local dev with SQLite:
# DATABASE_URL=sqlite:///pea_tracker.db

# Intraday live quotes (APScheduler)
ENABLE_INTRADAY=false
INTRADAY_INTERVAL_MINUTES=10
MARKET_OPEN_HOUR=9
MARKET_CLOSE_HOUR=17.5
